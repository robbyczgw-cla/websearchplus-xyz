{
  "version": 2,
  "builds": [
    {"src": "index.html", "use": "@vercel/static"},
    {"src": "providers.html", "use": "@vercel/static"},
    {"src": "providers.md", "use": "@vercel/static"},
    {"src": "assets/**", "use": "@vercel/static"}
  ],
  "routes": [
    {"src": "/assets/(.*)", "dest": "/assets/$1"},
    {"src": "/providers.html", "dest": "/providers.html"},
    {"src": "/providers.md", "dest": "/providers.md"},
    {"src": "/(.*)", "dest": "/index.html"}
  ]
}
